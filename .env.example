# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Demo owner used when Supabase is not configured
NEXT_PUBLIC_DEMO_OWNER_EMAIL=ali212@icloud.com
NEXT_PUBLIC_DEMO_OWNER_PASSWORD=123123
NEXT_PUBLIC_DEMO_OTP=123123

# Multi-Tenant
NEXT_PUBLIC_ROOT_DOMAIN=saloni.sa

# WhatsApp Business API
# Personal WhatsApp numbers cannot be used directly by this app.
# Use a Meta WhatsApp Business Cloud API phone number, approved OTP/marketing templates, and a webhook verify token.
WHATSAPP_BUSINESS_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_APP_SECRET=your-meta-app-secret

# Payment Gateway (Moyasar)
MOYASAR_SECRET_KEY=your-moyasar-secret-key
MOYASAR_PUBLIC_KEY=your-moyasar-public-key

# Or Tap Payments
TAP_SECRET_KEY=your-tap-secret-key

# App Settings
NEXT_PUBLIC_APP_NAME=سالوني
NEXT_PUBLIC_APP_URL=https://saloni.sa
NEXT_PUBLIC_DEFAULT_LOCALE=ar
NEXT_PUBLIC_DEFAULT_CURRENCY=SAR

# Redis (for caching and sessions)
REDIS_URL=redis://localhost:6379

# Sentry (optional)
NEXT_PUBLIC_SENTRY_DSN=
